function run(){var b=$response.body;if(!b)return $done({body:b});try{var d=JSON.parse(b);if(d.data){d.data.is_vip=true;d.data.vip_level=3;d.data.vip_type=3;d.data.is_svip=true;d.data.svip_level=3;d.data.svip_type=3;d.data.svip_expire="2099-09-19";d.data.vip_expire="2099-09-19";d.data.ad_free=true;d.data.daily_download=9999;d.data.download_count=9999}$done({body:JSON.stringify(d)})}catch(e){$done({body:b})}}run()